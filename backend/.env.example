# Server Configuration
PORT=8080
ENV=development

# Database Configuration
DATABASE_URL=postgres://postgres:password@localhost:5432/clawpay?sslmode=disable

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-here

# Blockchain Configuration
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# Contract Addresses (update after deployment)
USD1_ADDRESS=0x0000000000000000000000000000000000000000
DID_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
DUAL_DID_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REPUTATION_ADDRESS=0x0000000000000000000000000000000000000000
DYNAMIC_PRICING_ADDRESS=0x0000000000000000000000000000000000000000
INSURANCE_POOL_ADDRESS=0x0000000000000000000000000000000000000000
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Email SMTP Configuration (Required for email authentication in production)
# If not configured, verification codes will be returned in API response (development mode only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@clawpay.io
SMTP_FROM_NAME=ClawPay
